<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="CFTunnel"
           Manufacturer="imtaqin.id"
           Version="1.0.1"
           UpgradeCode="4E884968-D133-45B9-A3B5-70535561C69F"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of CFTunnel is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="CFTunnel">
        <Component Id="MainExe" Guid="710F0361-4BA6-4545-A632-E7E29F12111F">
          <File Id="CFTunnelExe"
                Source="..\publish\CFTunnel.exe"
                KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="8B1D3A67-2F94-4C1B-9E05-6A7D4F28C3E1">
        <Shortcut Id="StartMenuCFTunnel"
                  Name="CFTunnel"
                  Description="Cloudflare Tunnel Manager"
                  Target="[INSTALLFOLDER]CFTunnel.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveStartMenu" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\CFTunnel" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="C4F7E9A2-5D18-4B36-8F60-1E92A7B5D4C8">
        <Shortcut Id="DesktopCFTunnel"
                  Name="CFTunnel"
                  Description="Cloudflare Tunnel Manager"
                  Target="[INSTALLFOLDER]CFTunnel.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\CFTunnel" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="CFTunnel" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>
  </Package>
</Wix>
